{
  "permissions": {
    "allow": [
      "Bash(glab milestone list *)",
      "Bash(glab issue list *)",
      "Bash(glab mr list *)",
      "Bash(glab mr view *)",
      "Bash(glab issue view *)",
      "Bash(glab ci status *)"
    ]
  },
  "hooks": {
    "UserPromptSubmit": [
      {
        "hooks": [
          {
            "type": "command",
            "command": ".claude/hooks/pre-mr-security-gate.sh",
            "timeout": 10,
            "statusMessage": "Pre-MR security gate…"
          }
        ]
      }
    ],
    "PreToolUse": [
      {
        "matcher": "Edit|Write",
        "hooks": [
          {
            "type": "command",
            "command": ".claude/hooks/pre-tool-safety.sh",
            "timeout": 10000
          }
        ]
      }
    ],
    "PostToolUse": [
      {
        "matcher": "Write|Edit",
        "hooks": [
          {
            "type": "command",
            "command": "jq -r '.tool_input.file_path // empty' | { read -r f; [[ \"$f\" =~ packages/web/src/(features|components)/.*\\.[tj]sx?$ ]] && printf '{\"systemMessage\":\"🎤 UI changed — run /voice-of-customer before opening the MR\"}\\n'; } 2>/dev/null || true",
            "statusMessage": "Checking for VoC reminder…"
          }
        ]
      }
    ]
  }
}
