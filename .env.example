# TruePPM production environment — copy to .env and fill in values.
#   cp .env.example .env
#   chmod 600 .env

# ── Domain ──────────────────────────────────────────────────────────────────
DOMAIN=trueppm.example.com

# ── TLS ─────────────────────────────────────────────────────────────────────
# letsencrypt | selfsigned | none
TLS_MODE=letsencrypt
# Required only when TLS_MODE=letsencrypt
CERTBOT_EMAIL=ops@example.com

# ── Django ───────────────────────────────────────────────────────────────────
# REQUIRED: at least 32 characters. Production refuses to boot otherwise (#566).
# Generate with: python3 -c "import secrets; print(secrets.token_urlsafe(50))"
SECRET_KEY=REPLACE-WITH-A-LONG-RANDOM-STRING-AT-LEAST-32-CHARS-LONG

ALLOWED_HOSTS=trueppm.example.com

# ── Database ─────────────────────────────────────────────────────────────────
DB_PASSWORD=change-me

# ── Redis ────────────────────────────────────────────────────────────────────
REDIS_PASSWORD=change-me

# ── Admin bootstrap ──────────────────────────────────────────────────────────
# Email for the first superuser (password is auto-generated and written to
# TRUEPPM_ADMIN_PASSWORD_FILE; retrieve with the command in init-prod.sh).
DJANGO_SUPERUSER_EMAIL=admin@trueppm.example.com

# ── Integrations ─────────────────────────────────────────────────────────────
# REQUIRED once any user connects an account (GitHub/GitLab PAT) or the
# integrations feature is used: a Fernet key used to encrypt stored credentials.
# The app raises ImproperlyConfigured on first integration use if this is unset.
# Generate with:
#   python3 -c "from cryptography.fernet import Fernet; print(Fernet.generate_key().decode())"
INTEGRATION_ENCRYPTION_KEY=

# ── Attachment storage ───────────────────────────────────────────────────────
# Task attachments default to local FileSystemStorage, which is EPHEMERAL in a
# containerized deploy — uploads are lost on every pod restart. For production,
# point this at a persistent object-storage backend (S3/MinIO via django-storages):
#   TRUEPPM_DEFAULT_FILE_STORAGE=storages.backends.s3.S3Storage
# prod refuses to boot on the local default unless you explicitly opt in (e.g.
# when local disk is backed by a persistent volume):
#   TRUEPPM_ALLOW_LOCAL_ATTACHMENT_STORAGE=true
# TRUEPPM_DEFAULT_FILE_STORAGE=
# TRUEPPM_ALLOW_LOCAL_ATTACHMENT_STORAGE=false

# ── Cross-origin / CSRF ──────────────────────────────────────────────────────
# Required only when the web app is served from a different origin than the API
# (split-origin or subdomain-split deploy). Comma-separated, scheme included.
#   CSRF_TRUSTED_ORIGINS=https://app.trueppm.example.com,https://api.trueppm.example.com
# CSRF_TRUSTED_ORIGINS=

# ── Auth refresh cookie ──────────────────────────────────────────────────────
# The JWT refresh token rides in an httpOnly, Secure, SameSite=Strict cookie
# (never exposed to JavaScript, so XSS cannot steal it). The access token is held
# in browser memory only. These defaults are correct for a standard same-origin
# HTTPS deploy — leave them unset.
#
# SECURE defaults to true; the browser drops a Secure cookie over plain HTTP, so
# only set it false on a non-HTTPS dev/preview host (the dev settings already do
# this for localhost).
# AUTH_REFRESH_COOKIE_SECURE=true
#
# SameSite=Strict blocks the cookie on any cross-site request. A split-origin
# deploy (web served from a different origin than the API) must relax this to
# "Lax" or "None" so the refresh request carries the cookie; with "None" the
# cookie must also be Secure (HTTPS).
# AUTH_REFRESH_COOKIE_SAMESITE=Strict
#
# Cookie name and the path it is scoped to (the refresh endpoint). Override only
# if you reverse-proxy the API under a non-default base path.
# AUTH_REFRESH_COOKIE_NAME=trueppm_refresh
# AUTH_REFRESH_COOKIE_PATH=/api/v1/auth/token/refresh/

# ── Content-Security-Policy ──────────────────────────────────────────────────
# A strict CSP header (including frame-ancestors 'none') is sent on every API
# response. The defaults work for a standard same-origin deploy where the SPA is
# served from the same origin as the API.
#
# CSP_CONNECT_SRC controls which origins the browser may open XHR / fetch /
# WebSocket connections to. The default is "'self' wss:". If you serve the SPA
# from a DIFFERENT origin than the API (split-origin), add that API origin and
# its wss:// origin so the browser is allowed to reach them. Space-separated,
# each source quoted as CSP expects.
#   CSP_CONNECT_SRC='self' https://api.trueppm.example.com wss://api.trueppm.example.com
# CSP_CONNECT_SRC='self' wss:

# ── Image version ────────────────────────────────────────────────────────────
APP_VERSION=latest
