#!/usr/bin/env bash
# scripts/wt — git worktree helper for parallel multi-issue work.
#
# Usage:
#   scripts/wt new <issue|branch-name>    Create a worktree + branch off origin/main.
#                                         Checks out the issue (status::wip label +
#                                         comment) so parallel agents don't grab it;
#                                         refuses an already-checked-out issue unless
#                                         --force is passed to take it over.
#   scripts/wt claim <issue> [--force]    Check out an issue WITHOUT creating a
#                                         worktree yet (you picked it up but haven't
#                                         started). Same lock as `new`.
#   scripts/wt release <issue>            Release an issue check-out (clear the label).
#   scripts/wt list                       List active worktrees and WIP count.
#   scripts/wt remove <issue|name>        Remove a worktree by issue # or name; releases
#                                         its issue check-out.
#   scripts/wt prune                      Remove worktrees whose branches were merged
#                                         to main and deleted on origin. Refuses to
#                                         remove worktrees with uncommitted work.
#                                         Releases each pruned worktree's check-out.
#   scripts/wt doctor                     Verify symlinks and docker-stack reuse.
#   scripts/wt help                       Show this help.
#
# Safe by construction: parallel agents can self-serve `wt new`/`wt remove`
# without a human coordinating checkouts. Three structural guards, not process
# discipline, keep one agent from stomping another's worktree:
#   1. New branches are created with --no-track (no upstream to origin/main), so a
#      fresh, uncommitted, unpushed worktree is never confused with a merged-and-
#      deleted branch — the bug that made `wt prune` reap fresh worktrees.
#   2. Each worktree carries a `.wt-owner` marker; `wt prune` honors a freshness
#      grace window (TRUEPPM_WT_GRACE_MIN, default 30) and refuses to reap a
#      worktree younger than it unless --force.
#   3. Each worktree gets its OWN Postgres test DB (TRUEPPM_TEST_DB in .envrc), so
#      parallel `pytest` runs never collide — no external mutex required.
#
# Issue check-out lock: because all agents share one GitLab identity, an assignee
# or a claim-comment does not stop a parallel agent from grabbing the same issue.
# `wt new`/`wt claim` apply a `status::wip` scoped label plus a check-out comment
# as an advisory signal, and refuse an issue that already carries it. The lock is
# best-effort visibility only — if glab is unavailable the worktree is still
# created (with a warning); correctness rests on the local guards above, not the
# label.
#
# Worktrees live at $TRUEPPM_WT_BASE (default: ../trueppm-wt relative to the
# main checkout). Each worktree symlinks packages/api/.venv and packages/web/node_modules
# back to the main checkout so dev deps aren't duplicated. The running Docker stack
# is shared via COMPOSE_PROJECT_NAME=trueppm, exported via .envrc for direnv users.
#
# WIP discipline: warns at 8 active worktrees, errors at 10. Override with
# TRUEPPM_WT_CAP if you really need more (you probably don't).

set -euo pipefail

# ---------------------------------------------------------------------------
# Configuration
# ---------------------------------------------------------------------------

CURRENT_TOPLEVEL="$(git rev-parse --show-toplevel 2>/dev/null || { echo "wt: not in a git repo" >&2; exit 1; })"
# REPO_ROOT must always point at the main checkout, even when this script is
# invoked from inside a secondary worktree. Use git-common-dir's parent: in the
# main checkout that's ".git" → "."; in a worktree that's "<main>/.git" → "<main>".
GIT_COMMON_DIR="$(git rev-parse --git-common-dir)"
case "$GIT_COMMON_DIR" in
  /*) REPO_ROOT="$(dirname "$GIT_COMMON_DIR")" ;;
  *)  REPO_ROOT="$(cd "$CURRENT_TOPLEVEL" && cd "$(dirname "$GIT_COMMON_DIR")" && pwd)" ;;
esac
WT_BASE="${TRUEPPM_WT_BASE:-${REPO_ROOT%/*}/trueppm-wt}"
WT_CAP="${TRUEPPM_WT_CAP:-10}"
WT_WARN="${TRUEPPM_WT_WARN:-8}"
COMPOSE_PROJECT_NAME_DEFAULT="trueppm"
# Scoped label used as the issue check-out lock. Scoped (key `status::`) so it is
# mutually exclusive with any other `status::*` label GitLab already carries.
WT_LOCK_LABEL="${TRUEPPM_WT_LOCK_LABEL:-status::wip}"
# Freshness grace window (minutes): `prune` refuses to reap a worktree younger
# than this unless --force. This is the structural guard that stops a parallel
# agent's just-created worktree — nothing committed or pushed yet — from being
# false-pruned out from under it. Set TRUEPPM_WT_GRACE_MIN=0 to disable.
WT_GRACE_MIN="${TRUEPPM_WT_GRACE_MIN:-30}"
WT_GRACE_SEC=$(( WT_GRACE_MIN * 60 ))
# Per-worktree owner/liveness marker, stamped at creation (see write_owner_marker).
WT_OWNER_FILE=".wt-owner"

# ---------------------------------------------------------------------------
# Output helpers
# ---------------------------------------------------------------------------

if [[ -t 1 ]]; then
  C_RED='\033[31m'; C_YELLOW='\033[33m'; C_GREEN='\033[32m'; C_DIM='\033[2m'; C_OFF='\033[0m'
else
  C_RED=''; C_YELLOW=''; C_GREEN=''; C_DIM=''; C_OFF=''
fi

err()  { printf "${C_RED}wt: %s${C_OFF}\n" "$*" >&2; }
warn() { printf "${C_YELLOW}wt: %s${C_OFF}\n" "$*" >&2; }
ok()   { printf "${C_GREEN}wt: %s${C_OFF}\n" "$*"; }
say()  { printf "%s\n" "$*"; }
dim()  { printf "${C_DIM}%s${C_OFF}\n" "$*"; }

die()  { err "$*"; exit 1; }

# ---------------------------------------------------------------------------
# Helpers
# ---------------------------------------------------------------------------

# Slugify text: strip conventional-commit prefix, lowercase, drop non-alnum,
# collapse hyphens, cap length. The prefix strip keeps issue titles like
# "feat(web): foo bar baz" from becoming branch names like
# "feat-web-foo-bar-baz" that double the prefix once `feat/` is added.
slugify() {
  printf "%s" "$1" \
    | sed -E 's/^(feat|fix|chore|docs|test|refactor|perf|ci|build)(\([^)]*\))?:[[:space:]]*//' \
    | tr '[:upper:]' '[:lower:]' \
    | sed -E 's/[^a-z0-9]+/-/g' \
    | sed -E 's/^-+|-+$//g' \
    | cut -c1-40
}

# Derive a branch name from an arg. If the arg is purely numeric, it's an
# issue number — fetch its title via glab and build feat/<issue>-<slug>. If
# the arg already contains a slash, treat it as a full branch name.
derive_branch_name() {
  local input="$1"
  if [[ "$input" == */* ]]; then
    printf "%s" "$input"
    return
  fi
  if [[ "$input" =~ ^[0-9]+$ ]]; then
    if ! command -v glab >/dev/null 2>&1; then
      die "glab not installed; pass a full branch name like 'feat/$input-something'"
    fi
    local title
    title="$(glab issue view "$input" --output json 2>/dev/null \
             | python3 -c 'import json,sys; print(json.load(sys.stdin).get("title",""))' \
             || true)"
    if [[ -z "$title" ]]; then
      die "could not look up issue #$input via glab"
    fi
    local slug
    slug="$(slugify "$title")"
    printf "feat/%s-%s" "$input" "$slug"
    return
  fi
  # Anything else: treat as a slug, prefix with feat/.
  printf "feat/%s" "$(slugify "$input")"
}

# Count active worktrees (excludes the main checkout).
wt_count() {
  # grep -v exits 1 when it filters out every line — i.e. when the main checkout
  # is the only worktree. Under `set -o pipefail` that 1 propagates and `set -e`
  # would abort the whole script (silently, before the cap/warn checks run). The
  # `|| true` guard keeps the count at 0 in that case. Same fix as cmd_remove below.
  git -C "$REPO_ROOT" worktree list --porcelain \
    | awk '/^worktree /{print $2}' \
    | { grep -v "^${REPO_ROOT}$" || true; } \
    | wc -l \
    | tr -d ' '
}

# Find a worktree path by issue number or name fragment.
find_worktree() {
  local needle="$1"
  # Both greps exit 1 on no match (no other worktrees, or none matching needle).
  # Guard the chain with `|| true` so pipefail+`set -e` don't abort when the lookup
  # simply finds nothing — callers expect an empty string, not a crash.
  git -C "$REPO_ROOT" worktree list --porcelain \
    | awk '/^worktree /{print $2}' \
    | { grep -v "^${REPO_ROOT}$" | grep -E "/${needle}(-|$)" || true; } \
    | head -n1
}

# ---------------------------------------------------------------------------
# Owner / freshness marker
# ---------------------------------------------------------------------------
#
# Each worktree carries a `.wt-owner` file stamped at creation with who made it
# and when. `prune` reads its `created` epoch to enforce the grace window so a
# just-created worktree (agent still starting up, nothing committed yet) is
# never reaped out from under a parallel session. `wt list` reads it for the AGE
# column. It's a plain key=value file, untracked by git — the dirty-checks in
# remove/prune ignore it alongside .envrc.

write_owner_marker() {
  local path="$1" branch="$2" issue="$3"
  {
    printf 'created=%s\n' "$(date +%s)"
    printf 'created_iso=%s\n' "$(date -u '+%Y-%m-%dT%H:%M:%SZ')"
    printf 'host=%s\n' "$(hostname 2>/dev/null || echo unknown)"
    printf 'user=%s\n' "$(id -un 2>/dev/null || echo unknown)"
    printf 'branch=%s\n' "$branch"
    printf 'issue=%s\n' "${issue:--}"
    printf 'session=%s\n' "${CLAUDE_SESSION_ID:-${TERM_SESSION_ID:-unknown}}"
  } > "$path/$WT_OWNER_FILE" 2>/dev/null || true
}

# Read one key ($2) from a worktree's ($1) owner marker; empty if absent.
owner_field() {
  local path="$1" key="$2"
  [[ -f "$path/$WT_OWNER_FILE" ]] || return 0
  sed -n -E "s/^${key}=(.*)$/\1/p" "$path/$WT_OWNER_FILE" 2>/dev/null | head -n1
}

# Age of a worktree in seconds — from the owner marker's `created` epoch if
# present, else the directory mtime (GNU stat then BSD stat). Empty if unknown.
worktree_age_seconds() {
  local path="$1" created
  created="$(owner_field "$path" created)"
  if [[ -z "$created" ]]; then
    created="$(stat -c %Y "$path" 2>/dev/null || stat -f %m "$path" 2>/dev/null || true)"
  fi
  [[ "$created" =~ ^[0-9]+$ ]] || return 0
  printf '%s' "$(( $(date +%s) - created ))"
}

# True (0) if the worktree at $1 was created within the grace window.
within_grace() {
  local age
  (( WT_GRACE_SEC > 0 )) || return 1
  age="$(worktree_age_seconds "$1")"
  [[ "$age" =~ ^[0-9]+$ ]] || return 1
  (( age < WT_GRACE_SEC ))
}

# Human-friendly age: "3m", "2h", "5d" from a seconds count.
humanize_age() {
  local s="$1"
  [[ "$s" =~ ^[0-9]+$ ]] || { printf '?'; return; }
  if   (( s < 3600 ));  then printf '%dm' $(( s / 60 ))
  elif (( s < 86400 )); then printf '%dh' $(( s / 3600 ))
  else                       printf '%dd' $(( s / 86400 )); fi
}

# True (0) if branch $1 has its OWN upstream recorded (i.e. it was pushed with
# `git push -u`). Distinct from tracking origin/main: with the --no-track create
# below, this config key is absent until the first push, so it's an honest
# "pushed?" signal for `wt list`.
branch_pushed() {
  git -C "$REPO_ROOT" config --get "branch.${1}.remote" >/dev/null 2>&1
}

# ---------------------------------------------------------------------------
# Issue check-out lock
# ---------------------------------------------------------------------------
#
# Multi-agent collision guard. All agents share one GitLab identity, so an
# assignee or a claim-comment does not stop a parallel agent from grabbing the
# same issue. This lock uses the `status::wip` scoped label plus a check-out
# comment as the shared signal: `wt new`/`wt claim` refuse an already-claimed
# issue, and `wt remove`/`wt prune`/`wt release` clear it. All lock operations
# are best-effort — every one degrades to a warning (never a hard failure) when
# glab is missing or the API call fails, so worktree management never breaks on
# a network blip.

lock_available() { command -v glab >/dev/null 2>&1; }

# Extract the issue number encoded in a branch name (`feat/1462-foo` → 1462), or
# empty for a branch with no leading issue number (`chore/some-slug`). This is the
# single source for "which issue does this worktree lock", used by new/remove/prune.
issue_from_branch() {
  local branch="$1"
  if [[ "$branch" =~ ^[a-z]+/([0-9]+)- ]]; then printf "%s" "${BASH_REMATCH[1]}"; fi
}

# Print "locked" if issue $1 currently carries the lock label, else "".
issue_is_locked() {
  glab issue view "$1" --output json 2>/dev/null \
    | python3 -c "import json,sys; d=json.load(sys.stdin); print('locked' if '${WT_LOCK_LABEL}' in (d.get('labels') or []) else '')" \
    2>/dev/null || true
}

# Print the body of the most recent check-out comment on issue $1 (best effort;
# empty if none found or the comment JSON shape isn't recognized).
last_checkout_note() {
  glab issue view "$1" --comments --output json 2>/dev/null | python3 -c "
import json,sys
try:
    d=json.load(sys.stdin)
except Exception:
    sys.exit(0)
notes=d.get('Notes') or d.get('notes') or []
hits=[(n.get('body') or '') for n in notes if '🔒 checked out' in (n.get('body') or '')]
print(hits[-1] if hits else '')
" 2>/dev/null || true
}

# Create the scoped lock label if the project doesn't have it yet (idempotent).
ensure_lock_label() {
  glab label list 2>/dev/null | grep -qF "$WT_LOCK_LABEL" && return 0
  glab label create -n "$WT_LOCK_LABEL" -c "#ec9a29" \
    -d "Checked out by an agent/worktree (scripts/wt) — do not grab in parallel" \
    >/dev/null 2>&1 || true
}

# Apply the lock to issue $1: label + check-out comment recording branch/worktree.
apply_lock() {
  local issue="$1" branch="$2" path="$3" ts
  ensure_lock_label
  glab issue update "$issue" --label "$WT_LOCK_LABEL" >/dev/null 2>&1 \
    || warn "could not apply '$WT_LOCK_LABEL' to #$issue (check glab auth)"
  ts="$(date -u '+%Y-%m-%dT%H:%M:%SZ')"
  glab issue note "$issue" \
    -m "🔒 checked out ${ts} · branch \`${branch}\` · worktree \`${path}\`" \
    >/dev/null 2>&1 || warn "could not post check-out comment to #$issue"
}

# Release the lock on issue $1: remove the label and post a release comment.
clear_lock() {
  local issue="$1" branch="$2" ts
  glab issue update "$issue" --unlabel "$WT_LOCK_LABEL" >/dev/null 2>&1 || true
  ts="$(date -u '+%Y-%m-%dT%H:%M:%SZ')"
  glab issue note "$issue" -m "🔓 released ${ts} · branch \`${branch}\`" >/dev/null 2>&1 || true
}

# Guard used by new/claim: die if $1 is already checked out and --force wasn't given.
# $2 is the force flag (non-empty = force). No-op when glab is unavailable.
assert_claimable() {
  local issue="$1" force="$2" note
  lock_available || { warn "glab unavailable — the #$issue advisory label won't be set, but the local worktree dir + prune grace window still prevent a parallel agent from stomping this work"; return 0; }
  if [[ "$(issue_is_locked "$issue")" == "locked" && -z "$force" ]]; then
    err "issue #$issue is already checked out (label '$WT_LOCK_LABEL')."
    note="$(last_checkout_note "$issue")"
    [[ -n "$note" ]] && dim "  $note"
    die "another agent/worktree is likely on it. Re-run with --force to take it over."
  fi
}

# ---------------------------------------------------------------------------
# Subcommands
# ---------------------------------------------------------------------------

cmd_new() {
  local input="" force=""
  while [[ $# -gt 0 ]]; do
    case "$1" in
      --force) force="1"; shift ;;
      *)       [[ -z "$input" ]] && input="$1"; shift ;;
    esac
  done
  [[ -n "$input" ]] || die "usage: wt new <issue|branch-name> [--force]"
  local branch
  branch="$(derive_branch_name "$input")"
  local short_name="${branch##*/}"
  local target_path="${WT_BASE}/${short_name}"
  local issue
  issue="$(issue_from_branch "$branch")"

  # WIP cap check.
  local count
  count="$(wt_count)"
  if (( count >= WT_CAP )); then
    die "WIP cap reached (${count}/${WT_CAP}). Finish or remove one before starting another. Override with TRUEPPM_WT_CAP if you must."
  fi
  if (( count >= WT_WARN )); then
    warn "${count}/${WT_CAP} active worktrees — you're approaching the WIP cap"
  fi

  # Issue check-out lock: refuse fast (before touching the filesystem) if a
  # parallel agent already holds this issue, unless the caller forces a takeover.
  [[ -n "$issue" ]] && assert_claimable "$issue" "$force"

  # Fetch latest origin/main so the new branch is up-to-date.
  git -C "$REPO_ROOT" fetch origin main --quiet

  # Create the worktree.
  mkdir -p "$WT_BASE"
  if [[ -e "$target_path" ]]; then
    die "path already exists: $target_path"
  fi
  if git -C "$REPO_ROOT" rev-parse --verify "$branch" >/dev/null 2>&1; then
    git -C "$REPO_ROOT" worktree add "$target_path" "$branch"
  else
    # --no-track: the new branch must NOT adopt origin/main as its upstream.
    # If it did, `wt prune` could not tell a fresh 0-commit worktree from a
    # merged-and-deleted branch — both look like an ancestor of origin/main with
    # no origin/<branch> — and would false-prune the fresh one out from under a
    # running agent. The branch's real upstream is set on its first `git push -u`.
    git -C "$REPO_ROOT" worktree add --no-track "$target_path" -b "$branch" origin/main
  fi

  # Belt-and-suspenders: on the existing-branch path (or any git that ignores
  # --no-track), strip an origin/main upstream if one slipped through, for the
  # same false-prune reason above.
  if [[ "$(git -C "$REPO_ROOT" config --get "branch.${branch}.merge" 2>/dev/null || true)" == "refs/heads/main" ]]; then
    git -C "$REPO_ROOT" branch --unset-upstream "$branch" 2>/dev/null || true
  fi

  # Symlink shared dev deps. Both are absent in a fresh worktree.
  if [[ -e "$REPO_ROOT/packages/api/.venv" ]]; then
    ln -s "$REPO_ROOT/packages/api/.venv" "$target_path/packages/api/.venv"
    ok "symlinked packages/api/.venv → main checkout"
  else
    warn "main checkout has no packages/api/.venv; pre-push will fail until you create one"
  fi
  if [[ -e "$REPO_ROOT/packages/web/node_modules" ]]; then
    ln -s "$REPO_ROOT/packages/web/node_modules" "$target_path/packages/web/node_modules"
    ok "symlinked packages/web/node_modules → main checkout"
  else
    warn "main checkout has no packages/web/node_modules; run 'cd packages/web && npm ci' in main first"
  fi

  # Per-worktree Postgres test-DB name so parallel `pytest` runs don't collide
  # on one shared `test_trueppm` (which previously forced an out-of-band flock
  # mutex — and flock(1) is absent on macOS). Sanitized to a valid identifier and
  # length-capped; honored by packages/api/src/trueppm_api/settings/dev.py.
  local db_slug
  db_slug="$(printf '%s' "$short_name" | tr '[:upper:]' '[:lower:]' | tr -c 'a-z0-9' '_' | cut -c1-32)"
  local test_db="test_trueppm_wt_${db_slug}"

  # .envrc for direnv users. No-op if direnv isn't installed.
  cat > "$target_path/.envrc" <<EOF
# Auto-generated by scripts/wt. Reuses the running Docker stack from the main
# checkout via the shared compose project name. Without this, make pre-push
# can't find the running api container.
export COMPOSE_PROJECT_NAME=${COMPOSE_PROJECT_NAME_DEFAULT}
# Isolated test database for this worktree so pytest can run in parallel with
# other worktrees without colliding on a shared test DB. Honored by
# packages/api/src/trueppm_api/settings/dev.py.
export TRUEPPM_TEST_DB=${test_db}
EOF

  # Note: we deliberately do NOT write to .git/worktrees/<name>/info/exclude —
  # git treats info/exclude as shared across all worktrees (it reads from the
  # common gitdir, not the per-worktree subdir). The dirty check in `wt remove`
  # filters out our auto-created files instead.

  # Owner/freshness marker — powers the prune grace window and the `wt list` AGE
  # column so a parallel agent's fresh worktree is visibly, structurally protected.
  write_owner_marker "$target_path" "$branch" "$issue"

  # Check out the issue now that the worktree exists (best-effort GitLab lock).
  if [[ -n "$issue" ]] && lock_available; then
    apply_lock "$issue" "$branch" "$target_path"
    if [[ -n "$force" ]]; then
      ok "took over check-out of #$issue (forced; '$WT_LOCK_LABEL' applied)"
    else
      ok "checked out #$issue ('$WT_LOCK_LABEL' applied)"
    fi
  fi

  ok "created worktree at $target_path on branch $branch"
  say ""
  dim "  cd $target_path"
  if command -v direnv >/dev/null 2>&1; then
    dim "  direnv allow                           # picks up COMPOSE_PROJECT_NAME"
  else
    dim "  source .envrc                          # or set COMPOSE_PROJECT_NAME manually"
  fi
}

cmd_list() {
  local count
  count="$(wt_count)"
  printf "Active worktrees (%s/%s):\n\n" "$count" "$WT_CAP"
  if (( count > 0 )); then
    printf "  %-50s  %-6s  %-4s  %-6s  %s\n" "BRANCH" "ISSUE" "AGE" "PUSHED" "PATH"
  fi
  # A bash loop (not awk) so each row can carry the owner-marker age, the issue
  # number, and an honest pushed? flag — the transparency that lets an operator
  # or agent see at a glance whose worktree is whose and which are safe to reap.
  local path branch issue pushed
  while IFS= read -r path; do
    [[ -z "$path" || "$path" == "$REPO_ROOT" ]] && continue
    branch="$(git -C "$path" rev-parse --abbrev-ref HEAD 2>/dev/null || echo '?')"
    issue="$(issue_from_branch "$branch")"
    [[ -n "$issue" ]] && issue="#$issue" || issue="—"
    branch_pushed "$branch" && pushed="yes" || pushed="no"
    printf "  %-50s  %-6s  %-4s  %-6s  %s\n" \
      "$branch" "$issue" "$(humanize_age "$(worktree_age_seconds "$path")")" "$pushed" "$path"
  done < <(git -C "$REPO_ROOT" worktree list --porcelain | awk '/^worktree /{print $2}')
  say ""
  if (( count == 0 )); then
    dim "  (none — use 'wt new <issue>' to create one)"
  elif (( count >= WT_WARN )); then
    warn "approaching WIP cap (${count}/${WT_CAP}); finish or remove some before starting more"
  fi
}

cmd_remove() {
  [[ $# -ge 1 ]] || die "usage: wt remove <issue|name>"
  local needle="$1"
  local path
  path="$(find_worktree "$needle")"
  [[ -n "$path" ]] || die "no worktree matches '$needle'"

  # Capture the issue before we remove the tree, so we can release its check-out.
  local rm_branch rm_issue
  rm_branch="$(git -C "$path" rev-parse --abbrev-ref HEAD 2>/dev/null || true)"
  rm_issue="$(issue_from_branch "$rm_branch")"

  local force="${2:-}"
  if [[ -d "$path" ]]; then
    # Tracked changes (staged or unstaged) — never auto-removable.
    local tracked_dirty
    tracked_dirty="$(git -C "$path" status --porcelain --untracked-files=no 2>/dev/null | wc -l | tr -d ' ')"
    if (( tracked_dirty > 0 )) && [[ "$force" != "--force" ]]; then
      die "$path has $tracked_dirty uncommitted change(s) to tracked files. Commit/push first, or re-run with --force."
    fi
    # Untracked files — auto-created ones (.envrc + our two symlinks) are
    # expected; anything else is the user's work-in-progress that we should
    # refuse to drop silently.
    local unexpected_untracked
    # grep -v exits 1 on no-match, which combined with pipefail would kill the
    # script. Trailing `|| true` keeps the count at 0 in the clean case.
    unexpected_untracked="$( ( git -C "$path" status --porcelain 2>/dev/null \
      | awk '/^\?\? / {print $2}' \
      | grep -Ev '^(\.envrc|\.wt-owner|packages/api/\.venv|packages/web/node_modules)$' \
      || true ) | wc -l | tr -d ' ')"
    if (( unexpected_untracked > 0 )) && [[ "$force" != "--force" ]]; then
      die "$path has $unexpected_untracked untracked file(s) beyond the auto-created set. Stash/commit them, or re-run with --force."
    fi
  fi

  # Always force git's own remove — the symlinks + .envrc we created are
  # "untracked" from git's POV and would otherwise block removal.
  git -C "$REPO_ROOT" worktree remove --force "$path"
  ok "removed worktree $path"

  # Release the issue check-out (best-effort).
  if [[ -n "$rm_issue" ]] && lock_available; then
    clear_lock "$rm_issue" "$rm_branch"
    ok "released check-out of #$rm_issue"
  fi
}

cmd_prune() {
  # Remove worktrees whose branches have been merged and deleted on origin.
  # Conservative by default: refuses to remove a worktree with uncommitted
  # tracked changes or unexpected untracked files. Pass --force to override
  # those guards (you really shouldn't).
  local force="${1:-}"

  say "Fetching origin with --prune to discover deleted remote branches…"
  git -C "$REPO_ROOT" fetch --prune --quiet origin

  local pruned=0
  local skipped=0
  local kept=0

  # Iterate over every worktree except the main checkout.
  while IFS= read -r path; do
    [[ -z "$path" || "$path" == "$REPO_ROOT" ]] && continue

    # Branch this worktree is on. If detached HEAD, skip (no upstream to compare).
    local branch
    branch="$(git -C "$path" rev-parse --abbrev-ref HEAD 2>/dev/null || true)"
    if [[ -z "$branch" || "$branch" == "HEAD" ]]; then
      dim "  $path: detached HEAD — skipped"
      kept=$((kept + 1))
      continue
    fi

    # Grace window: never reap a very fresh worktree. A parallel agent may be
    # mid-startup with nothing committed or pushed yet — the classic false-prune
    # that stomps another session's work. --force overrides.
    if [[ "$force" != "--force" ]] && within_grace "$path"; then
      dim "  $branch: created $(humanize_age "$(worktree_age_seconds "$path")") ago (< ${WT_GRACE_MIN}m grace) — skipped (fresh, may be in use)"
      kept=$((kept + 1))
      continue
    fi

    # Did this branch ever have an upstream? If not, it's local-only WIP.
    if ! git -C "$REPO_ROOT" config --get "branch.${branch}.remote" >/dev/null 2>&1; then
      dim "  $branch: never pushed — skipped"
      kept=$((kept + 1))
      continue
    fi

    # Does the remote branch still exist? (origin/<branch> resolvable.)
    if git -C "$REPO_ROOT" rev-parse --verify --quiet "origin/${branch}" >/dev/null; then
      dim "  $branch: still on origin — skipped"
      kept=$((kept + 1))
      continue
    fi

    # Remote gone. Is the local tip an ancestor of origin/main (= merged)?
    # If not, the branch was deleted without merging — refuse to drop the
    # work silently.
    if ! git -C "$REPO_ROOT" merge-base --is-ancestor "$branch" origin/main 2>/dev/null; then
      warn "  $branch: remote gone but local commits NOT in origin/main — skipped (force-delete manually if intentional)"
      kept=$((kept + 1))
      continue
    fi

    # Safe to consider for removal. Apply the same dirty-check as cmd_remove.
    local tracked_dirty unexpected_untracked
    tracked_dirty="$(git -C "$path" status --porcelain --untracked-files=no 2>/dev/null | wc -l | tr -d ' ')"
    unexpected_untracked="$( ( git -C "$path" status --porcelain 2>/dev/null \
      | awk '/^\?\? / {print $2}' \
      | grep -Ev '^(\.envrc|\.wt-owner|packages/api/\.venv|packages/web/node_modules)$' \
      || true ) | wc -l | tr -d ' ')"

    if [[ "$force" != "--force" ]] && (( tracked_dirty > 0 || unexpected_untracked > 0 )); then
      warn "  $branch: merged but has local work (tracked=$tracked_dirty, untracked=$unexpected_untracked) — skipped (use --force to drop)"
      skipped=$((skipped + 1))
      continue
    fi

    git -C "$REPO_ROOT" worktree remove --force "$path"
    ok "  $branch: removed (merged to main, remote gone)"
    # Release the issue check-out for the pruned branch (best-effort).
    local prune_issue
    prune_issue="$(issue_from_branch "$branch")"
    [[ -n "$prune_issue" ]] && lock_available && clear_lock "$prune_issue" "$branch"
    pruned=$((pruned + 1))
  done < <(git -C "$REPO_ROOT" worktree list --porcelain | awk '/^worktree /{print $2}')

  say ""
  say "Pruned: $pruned. Skipped (had local work): $skipped. Kept: $kept."
}

cmd_doctor() {
  say "TruePPM worktree health"
  say "======================="
  say ""

  # Are we currently inside a worktree (not the main checkout)?
  local here="$CURRENT_TOPLEVEL"
  if [[ "$here" == "$REPO_ROOT" ]]; then
    dim "  not currently in a worktree (in main checkout)"
  else
    say "  current worktree: $here"
    # Symlink checks
    for link in "packages/api/.venv" "packages/web/node_modules"; do
      if [[ -L "$here/$link" ]]; then
        local target
        target="$(readlink "$here/$link")"
        if [[ -e "$target" ]]; then
          ok "  $link → $target"
        else
          err "  $link → $target (broken)"
        fi
      elif [[ -e "$here/$link" ]]; then
        warn "  $link exists but is NOT a symlink (re-created locally; will waste disk)"
      else
        warn "  $link missing"
      fi
    done
    # COMPOSE_PROJECT_NAME check
    if [[ "${COMPOSE_PROJECT_NAME:-}" == "$COMPOSE_PROJECT_NAME_DEFAULT" ]]; then
      ok "  COMPOSE_PROJECT_NAME=${COMPOSE_PROJECT_NAME_DEFAULT}"
    else
      warn "  COMPOSE_PROJECT_NAME not set; pre-push won't find the shared docker stack. Run: source .envrc"
    fi
  fi

  # Docker stack reachable? Check that the API container is up by name
  # (compose project = trueppm → container name = trueppm-api-1).
  if command -v docker >/dev/null 2>&1; then
    local api_status
    api_status="$(docker ps --filter "name=^${COMPOSE_PROJECT_NAME_DEFAULT}-api-1$" --format '{{.Status}}' 2>/dev/null || true)"
    if [[ -n "$api_status" ]]; then
      ok "  docker container ${COMPOSE_PROJECT_NAME_DEFAULT}-api-1 is up ($api_status)"
    else
      warn "  no running ${COMPOSE_PROJECT_NAME_DEFAULT}-api-1 container; run 'make up' in the main checkout"
    fi
  else
    warn "  docker not installed; can't verify stack"
  fi

  say ""
  say "WIP: $(wt_count)/$WT_CAP active worktrees"
}

# Check out an issue without creating a worktree — for "I picked it up but
# haven't started" so a parallel agent sees the claim immediately.
cmd_claim() {
  local issue="" force=""
  while [[ $# -gt 0 ]]; do
    case "$1" in
      --force) force="1"; shift ;;
      *)       [[ -z "$issue" ]] && issue="$1"; shift ;;
    esac
  done
  [[ "$issue" =~ ^[0-9]+$ ]] || die "usage: wt claim <issue-number> [--force]"
  lock_available || die "glab not available — cannot claim #$issue"
  assert_claimable "$issue" "$force"
  apply_lock "$issue" "(not started)" "(claim only — no worktree yet)"
  if [[ -n "$force" ]]; then
    ok "took over check-out of #$issue (forced; no worktree yet)"
  else
    ok "checked out #$issue ('$WT_LOCK_LABEL' applied; no worktree yet)"
  fi
}

# Manually release an issue check-out (e.g. a `claim` you never turned into a
# worktree, or a stale lock from a crashed session).
cmd_release() {
  [[ $# -ge 1 ]] || die "usage: wt release <issue-number>"
  local issue="$1"
  [[ "$issue" =~ ^[0-9]+$ ]] || die "release needs a numeric issue number"
  lock_available || die "glab not available — cannot release #$issue"
  clear_lock "$issue" "(manual release)"
  ok "released check-out of #$issue"
}

cmd_help() {
  sed -n '2,/^$/p' "$0" | sed -E 's/^# ?//'
}

# ---------------------------------------------------------------------------
# Dispatcher
# ---------------------------------------------------------------------------

case "${1:-help}" in
  new)     shift; cmd_new "$@" ;;
  claim)   shift; cmd_claim "$@" ;;
  release) shift; cmd_release "$@" ;;
  list|ls) cmd_list ;;
  remove|rm) shift; cmd_remove "$@" ;;
  prune)   shift; cmd_prune "$@" ;;
  doctor)  cmd_doctor ;;
  help|--help|-h) cmd_help ;;
  *)       err "unknown subcommand: $1"; cmd_help; exit 2 ;;
esac
