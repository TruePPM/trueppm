{
  "name": "trueppm-web",
  "version": "0.1.0-alpha.1",
  "license": "Apache-2.0",
  "type": "module",
  "engines": {
    "node": ">=20.0"
  },
  "scripts": {
    "dev": "vite",
    "build": "tsc -b && vite build",
    "preview": "vite preview",
    "lint": "eslint src/",
    "lint:fix": "eslint src/ --fix",
    "format": "prettier --write src/",
    "format:check": "prettier --check src/",
    "typecheck": "tsc --noEmit",
    "test": "NODE_OPTIONS=--max-old-space-size=4096 vitest run",
    "test:ui": "NODE_OPTIONS=--max-old-space-size=4096 vitest --ui",
    "test:coverage": "NODE_OPTIONS=--max-old-space-size=4096 vitest run src/api src/features src/hooks src/lib src/stores --coverage",
    "test:e2e": "playwright test",
    "test:e2e:ui": "playwright test --ui",
    "generate:types": "openapi-typescript http://localhost:8000/api/schema/ -o src/api/types.ts"
  },
  "dependencies": {
    "@dnd-kit/core": "^6.3.1",
    "@dnd-kit/sortable": "^10.0.0",
    "@dnd-kit/utilities": "^3.2.2",
    "@tanstack/react-query": "^5.0.0",
    "@tanstack/react-virtual": "^3.13.23",
    "axios": "^1.7.0",
    "html-to-image": "^1.11.13",
    "jspdf": "^4.2.1",
    "react": "^19.0.0",
    "react-dom": "^19.0.0",
    "react-router": "^7.13.1",
    "recharts": "^3.8.1",
    "zustand": "^5.0.0"
  },
  "devDependencies": {
    "@playwright/test": "^1.58.2",
    "@tanstack/react-query-devtools": "^5.0.0",
    "@testing-library/jest-dom": "^6.6.0",
    "@testing-library/react": "^16.0.0",
    "@testing-library/user-event": "^14.5.0",
    "@types/node": "^25.5.0",
    "@types/react": "^19.0.0",
    "@types/react-dom": "^19.0.0",
    "@typescript-eslint/eslint-plugin": "^8.0.0",
    "@typescript-eslint/parser": "^8.0.0",
    "@vitejs/plugin-react": "^4.3.0",
    "@vitest/coverage-istanbul": "^3.2.4",
    "@vitest/ui": "^3.0.0",
    "autoprefixer": "^10.4.0",
    "eslint": "^9.0.0",
    "eslint-config-prettier": "^9.1.0",
    "eslint-plugin-jsx-a11y": "^6.10.0",
    "eslint-plugin-react": "^7.37.0",
    "eslint-plugin-react-hooks": "^5.0.0",
    "globals": "^17.4.0",
    "jsdom": "^25.0.0",
    "openapi-typescript": "^7.4.0",
    "postcss": "^8.4.0",
    "prettier": "^3.3.0",
    "tailwindcss": "^3.4.0",
    "typescript": "~5.6.0",
    "vite": "^6.0.0",
    "vitest": "^3.0.0"
  }
}
