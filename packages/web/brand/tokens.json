{
  "$schema": "https://schemas.trueppm.io/tokens-1.0.json",
  "meta": {
    "brand": "TruePPM",
    "version": "1.0.0",
    "palette": "True Navy · Truth Sage · Reversed Ink",
    "note": "Navy ink reverses to pale on dark; sage holds in both modes."
  },
  "color": {
    "brand": {
      "navy":     { "value": "#1B2A4A", "name": "True Navy" },
      "sage":     { "value": "#4FA884", "name": "Truth Sage" },
      "reversed": { "value": "#E9EDF3", "name": "Reversed Ink" }
    },
    "navy": {
      "50": "#EEF1F7", "100": "#D8DFEC", "200": "#B0BDD3", "300": "#8194B5",
      "400": "#556C94", "500": "#344A72", "600": "#243A5E", "700": "#1B2A4A",
      "800": "#15223C", "900": "#0E1626"
    },
    "sage": {
      "50": "#EDF7F2", "100": "#D3ECE0", "200": "#AEDCC8", "300": "#84CBAC",
      "400": "#66B998", "500": "#4FA884", "600": "#3E8C6D", "700": "#316F57",
      "800": "#275844", "900": "#1B3D2F"
    },
    "slate": {
      "50": "#F7F8FA", "100": "#EFF1F4", "200": "#E2E6EC", "300": "#CBD2DB",
      "400": "#9AA4B2", "500": "#6B7585", "600": "#4D5765", "700": "#353E4B",
      "800": "#232A34", "900": "#141921"
    },
    "semantic": {
      "success":  { "value": "#3E8C6D", "bg": "#E7F3EC", "use": "on-track" },
      "info":     { "value": "#2F6FD1", "bg": "#E5EEFB", "use": "informational" },
      "warning":  { "value": "#DE9326", "bg": "#FBF0DC", "use": "at-risk" },
      "critical": { "value": "#CF4438", "bg": "#FBE6E4", "use": "blocked / on critical path" }
    },
    "light": {
      "bg": "#F6F7F9",
      "surface": "#FFFFFF",
      "surfaceRaised": "#FBFCFD",
      "surfaceSunken": "#F2F4F7",
      "border": "#E2E6EC",
      "borderStrong": "#CBD2DB",
      "textPrimary": "#1B2A4A",
      "textSecondary": "#5A6473",
      "textTertiary": "#8A94A3",
      "textInverse": "#FFFFFF",
      "textLink": "#3E8C6D"
    },
    "dark": {
      "bg": "#0E1626",
      "surface": "#15223C",
      "surfaceRaised": "#1B2A4A",
      "surfaceSunken": "#0B1220",
      "border": "#2A3A57",
      "borderStrong": "#3A4D70",
      "textPrimary": "#E9EDF3",
      "textSecondary": "#9BAAC6",
      "textTertiary": "#6E7E9A",
      "textInverse": "#1B2A4A",
      "textLink": "#66B998",
      "success": "#66B998",
      "warning": "#E9B35A",
      "critical": "#E8645A",
      "info": "#6FA0E8"
    }
  },
  "font": {
    "display": "\"Space Grotesk\", system-ui, sans-serif",
    "sans": "\"Inter\", system-ui, sans-serif",
    "mono": "\"JetBrains Mono\", ui-monospace, monospace"
  },
  "fontSize": {
    "displayXl": "3.75rem", "displayL": "2.75rem", "h1": "2.125rem",
    "h2": "1.625rem", "h3": "1.25rem", "bodyLg": "1.125rem", "body": "1rem",
    "bodySm": "0.875rem", "caption": "0.8125rem", "overline": "0.75rem"
  },
  "fontWeight": { "regular": 400, "medium": 500, "semibold": 600, "bold": 700 },
  "lineHeight": { "tight": 1.1, "snug": 1.3, "normal": 1.55 },
  "letterSpacing": { "tight": "-0.02em", "normal": "0", "wide": "0.14em" },
  "space": {
    "0": "0", "1": "0.25rem", "2": "0.5rem", "3": "0.75rem", "4": "1rem",
    "5": "1.25rem", "6": "1.5rem", "8": "2rem", "10": "2.5rem", "12": "3rem",
    "16": "4rem", "20": "5rem", "24": "6rem"
  },
  "radius": {
    "xs": "4px", "sm": "6px", "md": "8px", "lg": "12px",
    "xl": "16px", "2xl": "20px", "full": "9999px"
  },
  "shadow": {
    "sm": "0 1px 2px rgba(20,25,33,0.06)",
    "md": "0 4px 16px rgba(20,25,33,0.08)",
    "lg": "0 12px 32px -8px rgba(20,25,33,0.14)"
  },
  "motion": {
    "durFast": "120ms", "dur": "200ms", "durSlow": "320ms",
    "easeStandard": "cubic-bezier(0.2,0.7,0.2,1)",
    "easeIn": "cubic-bezier(0.4,0,1,1)",
    "easeOut": "cubic-bezier(0,0,0.2,1)"
  }
}
