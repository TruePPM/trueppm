# In development, Vite proxies /api/* to http://localhost:8000 (see vite.config.ts server.proxy).
# VITE_API_BASE_URL is only needed for production builds pointing at the deployed API.
# VITE_API_BASE_URL=https://api.yourdomain.com

# Build-time defaults for runtime feature flags (see src/lib/featureFlags.ts).
# JSON object of { flagName: boolean }. Runtime localStorage overrides win.
# Production builds: leave unset (everything defaults off).
# VITE_FEATURE_FLAGS={"schedule_build_mode_v1":true}
