{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://trueppm.com/schemas/seed/v1.json",
  "title": "TruePPM seed data v1",
  "description": "Canonical JSON seed format for sample projects and universal import/export (ADR-0109, epic #613). One document describes one program and its projects. Stable cross-references use file-local slugs and ltree wbs paths; UUIDs and derived fields (server_version, CPM outputs, short_id) are never present.",
  "type": "object",
  "additionalProperties": false,
  "required": ["schema_version", "program", "projects"],
  "properties": {
    "schema_version": {
      "type": "string",
      "description": "Schema major.minor. validate_seed() rejects unsupported majors.",
      "const": "1.0"
    },
    "program": { "$ref": "#/$defs/program" },
    "accounts": {
      "type": "array",
      "description": "User logins referenced by the seed. Created only when import runs with --create-users.",
      "items": { "$ref": "#/$defs/account" }
    },
    "calendars": {
      "type": "array",
      "items": { "$ref": "#/$defs/calendar" }
    },
    "resources": {
      "type": "array",
      "items": { "$ref": "#/$defs/resource" }
    },
    "risks": {
      "type": "array",
      "description": "Program-scoped risks. Project-scoped risks live under each project.",
      "items": { "$ref": "#/$defs/risk" }
    },
    "projects": {
      "type": "array",
      "minItems": 1,
      "items": { "$ref": "#/$defs/project" }
    }
  },
  "$defs": {
    "slug": {
      "type": "string",
      "description": "File-local stable identifier, kebab-case.",
      "pattern": "^[a-z0-9]+(-[a-z0-9]+)*$",
      "maxLength": 60
    },
    "wbsPath": {
      "type": "string",
      "description": "ltree path, e.g. \"1.2.3\". Per-project task identity.",
      "pattern": "^[A-Za-z0-9_]+(\\.[A-Za-z0-9_]+)*$",
      "maxLength": 255
    },
    "taskRef": {
      "type": "string",
      "description": "A task by wbs path. Bare for the enclosing project, or \"<project-slug>:<wbs-path>\" for a sibling project.",
      "pattern": "^([a-z0-9]+(-[a-z0-9]+)*:)?[A-Za-z0-9_]+(\\.[A-Za-z0-9_]+)*$"
    },
    "color": {
      "type": "string",
      "pattern": "^#[0-9A-Fa-f]{6}$"
    },
    "program": {
      "type": "object",
      "additionalProperties": false,
      "required": ["slug", "name", "methodology"],
      "properties": {
        "slug": {
          "$ref": "#/$defs/slug",
          "description": "Program natural key. Persisted into Program.code; re-import upserts on (workspace, code)."
        },
        "name": { "type": "string", "minLength": 1, "maxLength": 255 },
        "description": { "type": "string" },
        "methodology": { "enum": ["WATERFALL", "AGILE", "HYBRID"] },
        "color": { "$ref": "#/$defs/color" },
        "lead": {
          "$ref": "#/$defs/slug",
          "description": "Account slug of the program lead."
        }
      }
    },
    "account": {
      "type": "object",
      "additionalProperties": false,
      "required": ["slug", "username"],
      "properties": {
        "slug": { "$ref": "#/$defs/slug" },
        "username": { "type": "string", "minLength": 1, "maxLength": 150 },
        "email": { "type": "string", "format": "email" },
        "display_name": { "type": "string", "maxLength": 255 },
        "role": {
          "enum": ["VIEWER", "MEMBER", "SCHEDULER", "ADMIN", "OWNER"],
          "description": "Program membership role granted on import."
        }
      }
    },
    "calendar": {
      "type": "object",
      "additionalProperties": false,
      "required": ["slug", "name"],
      "properties": {
        "slug": { "$ref": "#/$defs/slug" },
        "name": { "type": "string", "minLength": 1, "maxLength": 255 },
        "working_days": {
          "type": "integer",
          "minimum": 0,
          "maximum": 127,
          "description": "Bitmask Mon=1..Sun=64. Default 31 (Mon-Fri)."
        },
        "hours_per_day": { "type": "number", "exclusiveMinimum": 0, "maximum": 24 },
        "timezone": { "type": "string", "maxLength": 64 }
      }
    },
    "resource": {
      "type": "object",
      "additionalProperties": false,
      "required": ["slug", "name"],
      "properties": {
        "slug": { "$ref": "#/$defs/slug" },
        "name": { "type": "string", "minLength": 1, "maxLength": 255 },
        "email": { "type": "string", "format": "email" },
        "job_role": { "type": "string", "maxLength": 120 },
        "max_units": {
          "type": "number",
          "exclusiveMinimum": 0,
          "maximum": 99.99,
          "description": "Availability fraction. 1.0 = full-time. 0.1 = 10% advisor."
        },
        "calendar": { "$ref": "#/$defs/slug" },
        "account": {
          "$ref": "#/$defs/slug",
          "description": "Optional account slug linking this resource to a user login (Resource.user)."
        }
      }
    },
    "estimate": {
      "type": "object",
      "additionalProperties": false,
      "required": ["optimistic", "most_likely", "pessimistic"],
      "description": "Three-point PERT estimate in working days. All-or-none: present means all three; omit entirely for unestimated tasks. Never set on summary or milestone tasks.",
      "properties": {
        "optimistic": { "type": "integer", "minimum": 0 },
        "most_likely": { "type": "integer", "minimum": 0 },
        "pessimistic": { "type": "integer", "minimum": 0 }
      }
    },
    "task": {
      "type": "object",
      "additionalProperties": false,
      "required": ["wbs_path", "name"],
      "properties": {
        "wbs_path": { "$ref": "#/$defs/wbsPath" },
        "name": { "type": "string", "minLength": 1, "maxLength": 512 },
        "type": { "enum": ["epic", "story", "task", "bug", "spike"] },
        "status": {
          "enum": ["BACKLOG", "NOT_STARTED", "IN_PROGRESS", "REVIEW", "ON_HOLD", "COMPLETE"]
        },
        "is_milestone": { "type": "boolean" },
        "duration": { "type": "integer", "minimum": 0 },
        "planned_start": { "type": "string", "format": "date" },
        "percent_complete": { "type": "number", "minimum": 0, "maximum": 100 },
        "notes": { "type": "string" },
        "estimate": { "$ref": "#/$defs/estimate" },
        "story_points": { "type": "integer", "minimum": 0 },
        "remaining_points": { "type": "integer", "minimum": 0 },
        "assignee": { "$ref": "#/$defs/slug" },
        "sprint": { "$ref": "#/$defs/slug" },
        "parent_epic": {
          "$ref": "#/$defs/wbsPath",
          "description": "wbs_path of the epic task grouping this story (Task.parent_epic)."
        },
        "dor": { "enum": ["idea", "refine", "ready"] },
        "sprint_rank": { "type": "integer", "minimum": 0 },
        "governance_class": { "enum": ["gated", "flow", "hybrid"] },
        "delivery_mode": { "enum": ["waterfall", "scrum", "kanban", "milestone"] },
        "color": { "$ref": "#/$defs/color" },
        "assignments": {
          "type": "array",
          "description": "Resource allocations on this task. assignee is the responsible user; assignments are capacity (Resource + units fraction of max_units).",
          "items": {
            "type": "object",
            "additionalProperties": false,
            "required": ["resource"],
            "properties": {
              "resource": { "$ref": "#/$defs/slug" },
              "units": { "type": "number", "exclusiveMinimum": 0, "maximum": 99.99 }
            }
          }
        }
      }
    },
    "dependency": {
      "type": "object",
      "additionalProperties": false,
      "required": ["predecessor", "successor", "dep_type"],
      "properties": {
        "predecessor": { "$ref": "#/$defs/taskRef" },
        "successor": { "$ref": "#/$defs/taskRef" },
        "dep_type": { "enum": ["FS", "SS", "FF", "SF"] },
        "lag": {
          "type": "integer",
          "description": "Calendar days. Positive = delay, negative = lead."
        }
      }
    },
    "sprint": {
      "type": "object",
      "additionalProperties": false,
      "required": ["slug", "name", "state", "start_date", "finish_date"],
      "properties": {
        "slug": { "$ref": "#/$defs/slug" },
        "name": { "type": "string", "minLength": 1, "maxLength": 255 },
        "goal": { "type": "string" },
        "notes": { "type": "string" },
        "start_date": { "type": "string", "format": "date" },
        "finish_date": { "type": "string", "format": "date" },
        "state": { "enum": ["PLANNED", "ACTIVE", "COMPLETED", "CANCELLED"] },
        "committed_points": { "type": "integer", "minimum": 0 },
        "completed_points": { "type": "integer", "minimum": 0 },
        "capacity_points": { "type": "integer", "minimum": 0 },
        "target_milestone": {
          "$ref": "#/$defs/wbsPath",
          "description": "wbs_path of a milestone task in the same project."
        }
      }
    },
    "baselineTask": {
      "type": "object",
      "additionalProperties": false,
      "required": ["task"],
      "properties": {
        "task": { "$ref": "#/$defs/wbsPath" },
        "start": { "type": "string", "format": "date" },
        "finish": { "type": "string", "format": "date" },
        "duration": { "type": "integer", "minimum": 0 },
        "story_points": { "type": "integer", "minimum": 0 }
      }
    },
    "baseline": {
      "type": "object",
      "additionalProperties": false,
      "required": ["name", "tasks"],
      "properties": {
        "name": { "type": "string", "minLength": 1, "maxLength": 255 },
        "is_active": { "type": "boolean" },
        "tasks": {
          "type": "array",
          "items": { "$ref": "#/$defs/baselineTask" }
        }
      }
    },
    "risk": {
      "type": "object",
      "additionalProperties": false,
      "required": ["slug", "title", "status", "probability", "impact"],
      "properties": {
        "slug": { "$ref": "#/$defs/slug" },
        "title": { "type": "string", "minLength": 1, "maxLength": 512 },
        "description": { "type": "string" },
        "status": { "enum": ["OPEN", "MITIGATING", "RESOLVED", "ACCEPTED", "CLOSED"] },
        "probability": { "type": "integer", "minimum": 1, "maximum": 5 },
        "impact": { "type": "integer", "minimum": 1, "maximum": 5 },
        "category": { "enum": ["TECHNICAL", "EXTERNAL", "ORGANIZATIONAL", "PROJECT_MANAGEMENT"] },
        "response": { "enum": ["AVOID", "MITIGATE", "TRANSFER", "ACCEPT"] },
        "mitigation_due_date": { "type": "string", "format": "date" },
        "trigger": { "type": "string" },
        "contingency": { "type": "string" },
        "notes": { "type": "string" },
        "owner": { "$ref": "#/$defs/slug" },
        "tasks": {
          "type": "array",
          "description": "Task refs this risk is linked to. Bare wbs path = enclosing project; \"<slug>:<wbs>\" = sibling project (program-scoped risks only).",
          "items": { "$ref": "#/$defs/taskRef" }
        }
      }
    },
    "project": {
      "type": "object",
      "additionalProperties": false,
      "required": ["slug", "name", "methodology", "start_date"],
      "properties": {
        "slug": { "$ref": "#/$defs/slug" },
        "name": { "type": "string", "minLength": 1, "maxLength": 255 },
        "description": { "type": "string" },
        "methodology": { "enum": ["WATERFALL", "AGILE", "HYBRID"] },
        "start_date": { "type": "string", "format": "date" },
        "calendar": { "$ref": "#/$defs/slug" },
        "code": { "type": "string", "maxLength": 12 },
        "default_view": { "enum": ["SCHEDULE", "BOARD", "TABLE", "OVERVIEW"] },
        "estimation_mode": { "enum": ["open", "suggest_approve", "pm_only"] },
        "agile_features": { "type": "boolean" },
        "board_columns": {
          "type": "array",
          "description": "Kanban column labels, in order.",
          "items": { "type": "string", "minLength": 1, "maxLength": 64 }
        },
        "tasks": {
          "type": "array",
          "items": { "$ref": "#/$defs/task" }
        },
        "dependencies": {
          "type": "array",
          "items": { "$ref": "#/$defs/dependency" }
        },
        "sprints": {
          "type": "array",
          "items": { "$ref": "#/$defs/sprint" }
        },
        "baselines": {
          "type": "array",
          "items": { "$ref": "#/$defs/baseline" }
        },
        "risks": {
          "type": "array",
          "items": { "$ref": "#/$defs/risk" }
        }
      }
    }
  }
}
