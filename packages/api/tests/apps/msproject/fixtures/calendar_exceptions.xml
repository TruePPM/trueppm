      <UID>1</UID>
      <Name>Calendar-Aware Resource</Name>
      <MaxUnits>1.0</MaxUnits>
      <CalendarUID>1</CalendarUID>
    </Resource>
  </Resources>

  <Assignments>
    <Assignment>
      <UID>1</UID>
      <TaskUID>1</TaskUID>
      <ResourceUID>1</ResourceUID>
      <Units>1.0</Units>
    </Assignment>
  </Assignments>
</Project>
