---
// Custom 404 that bypasses the Starlight content collection lookup
---
<!doctype html>
<html lang="en">
  <head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1" />
    <title>404 — TruePPM Docs</title>
    <style>
      body { font-family: system-ui, sans-serif; display: flex; align-items: center; justify-content: center; min-height: 100vh; margin: 0; background: #17181c; color: #eef0f6; }
      .container { text-align: center; max-width: 480px; padding: 2rem; }
      h1 { font-size: 3rem; margin: 0 0 0.5rem; color: #7b9ff9; }
      p { font-size: 1.125rem; margin: 0.5rem 0 1.5rem; color: #8b90a0; }
      a { color: #7b9ff9; text-decoration: none; border: 1px solid #7b9ff9; padding: 0.5rem 1.5rem; border-radius: 4px; }
      a:hover { background: #7b9ff9; color: #17181c; }
    </style>
  </head>
  <body>
    <div class="container">
      <h1>404</h1>
      <p>The page you're looking for doesn't exist.</p>
      <a href="/">Back to docs</a>
    </div>
  </body>
</html>
